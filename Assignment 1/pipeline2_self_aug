        plt.axis('off')

    plt.suptitle("Hard Samples (Active Learning)", fontsize=14)
    plt.tight_layout()

    if save:
        if iteration is not None:
            path = os.path.join(OUTPUT_DIR, f"hard_samples_iter_{iteration}.png")
        else:
            path = os.path.join(OUTPUT_DIR, "hard_samples.png")
        plt.savefig(path, dpi=300)
        print(f"[INFO] Saved hard samples at: {path}")

    plt.show()
    
    
   
# ==============================
# MAIN
# ==============================
if __name__ == "__main__":
        
    # ======================
    # LOAD / CACHE IMAGES
    # ======================
    if os.path.exists(IMAGES_CACHE):
        print("[INFO] Loading cached images...")
        images = np.load(IMAGES_CACHE)
    else:
        print("[INFO] Loading images from disk...")
        images = load_images(DATA_PATH)
        np.save(IMAGES_CACHE, images)

    # ==============================
    # STEP 1 — LOAD SEED MATRIX
    # ==============================

    matrix_path = os.path.join(OUTPUT_DIR, "label_matrix.csv")

    print(f"[INFO] Loading seed matrix from: {matrix_path}")

    matrix = np.loadtxt(matrix_path, delimiter=",", dtype=int)

    print("[INFO] Matrix shape:", matrix.shape)

    print(matrix)
 
    print("[INFO] Showing 10 samples per class...")
    show_class_samples(images, matrix, num_per_class=10)
    
    # ==============================
    # Step 2: AUGMENTED DATA
    # ==============================

    AUGMENTED_PATH = os.path.join(OUTPUT_DIR, "augmented_seed.npy")

    if os.path.exists(AUGMENTED_PATH):
        print("[INFO] Loading augmented data...")
        augmented_data = np.load(AUGMENTED_PATH)
    else:
        print("[INFO] Generating augmented data...")
        augmented_data = augment_seed(images, matrix)
        np.save(AUGMENTED_PATH, augmented_data)

    print("[INFO] Augmented shape:", augmented_data.shape)
    
    print("[INFO] Showing augmentation example...")
    show_augmentation_variants(augmented_data, class_id=3, sample_idx=0)
    
    # ==============================
    # STEP 3 — INITIAL SVM TRAINING
    # ==============================

    # build training set
    X_train, y_train, weights = build_training_set(augmented_data)
    
    X_train = list(X_train)
    y_train = list(y_train)
    weights = list(weights)


    # ==============================
    # FEATURES FOR FULL DATASET (CACHE)
    # ==============================
    FULL_FEATURES_PATH = os.path.join(OUTPUT_DIR, "full_features.npy")

    if os.path.exists(FULL_FEATURES_PATH):
        print("[INFO] Loading full features...")
        full_features = np.load(FULL_FEATURES_PATH)
    else:
        print("[INFO] Extracting full dataset features...")
        full_features = extract_hog_features(images)
        np.save(FULL_FEATURES_PATH, full_features)

    # initialize current labels
    current_labels = np.zeros(N, dtype=int)

    # initialize used indices
    used_indices = set()

    # add seed indices
    used_indices.update(matrix.flatten())

    
    # ==============================
    # ACTIVE LEARNING LOOP (Step 4–7)
    # ==============================

    # tracking
    history = []
    manual_count = 300
    pseudo_count = 0

    prev_acc = 0
    max_iter = 20

    for iteration in range(1, max_iter + 1):
        print(f"\n========== ITERATION {iteration} ==========")

        # convert to numpy
        X_np = np.array(X_train)
        y_np = np.array(y_train)
        w_np = np.array(weights)

        # extract features
        X_feat = extract_hog_features(X_np)

        # train SVM
        svm = train_svm(X_feat, y_np, w_np)

        # predict full dataset
        predicted_labels, scores = predict_full_dataset(svm, full_features)

        # evaluate
        acc, correct, total = check_accuracy(predicted_labels)
        print(f"[INFO] Accuracy: {acc*100:.2f}%")

        # ======================
        # STEP 4 — HARD SAMPLES
        # ======================
        hard_samples, margin = get_hard_samples(scores, used_indices)
        hard_labels = get_true_labels_for_samples(hard_samples)

        # update current_labels with hard labels
        current_labels[hard_samples] = hard_labels

        print(f"[INFO] Hard samples: {len(hard_samples)}")

        show_hard_samples(images, hard_samples, hard_labels, n=10, save=True, iteration=iteration)

        # ======================
        # STEP 5 — CONFIDENT SAMPLES
        # ======================
        confident_samples = get_confident_samples(
            predicted_labels, margin, used_indices
        )

        # update current_labels with pseudo labels
        current_labels[confident_samples] = predicted_labels[confident_samples]

        print(f"[INFO] Confident samples: {len(confident_samples)}")

        # ======================
        # UPDATE COUNTS
        # ======================
        manual_count += len(hard_samples)
        pseudo_count += len(confident_samples)

        # ======================
        # UPDATE USED INDICES
        # ======================
        used_indices.update(hard_samples)
        used_indices.update(confident_samples)

        # ======================
        # STEP 6 — UPDATE DATASET
        # ======================
        X_train, y_train, weights = update_training_set(
            X_train, y_train, weights,
            images, predicted_labels,
            hard_samples, hard_labels,
            confident_samples
        )

        # ======================
        # SAVE HISTORY
        # ======================
        history.append([
            iteration,
            acc * 100,
            len(hard_samples),
            len(confident_samples),
            manual_count,
            pseudo_count
        ])

        # ======================
        # STEP 7 — STOP CONDITIONS
        # ======================
        if acc >= 0.99:
            print("[INFO] Reached 99% accuracy!")
            break

        if abs(acc - prev_acc) < 0.001:
            print("[INFO] Converged (low improvement)")
            break

        prev_acc = acc
    
        
    # ==============================
    # SAVE ITERATION RESULTS
    # ==============================
    print("\n====== FINAL SUMMARY ======")
    print(f"Iterations: {iteration}")
    print(f"Final Accuracy: {acc*100:.2f}%")
    print(f"Total Manual Labels: {manual_count}")
    print(f"Total Pseudo Labels: {pseudo_count}")

    # estimated time
    manual_time_sec = manual_count * 10
    print(f"Estimated Manual Time: {manual_time_sec/60:.2f} minutes")
    print("===========================")
    
    csv_path = os.path.join(OUTPUT_DIR, "pipeline2_iterations.csv")

    with open(csv_path, "w", newline="") as f:
        writer = csv.writer(f)

        writer.writerow([
            "Iteration",
            "Accuracy (%)",
            "Hard Samples",
            "Pseudo Samples",
            "Total Manual",
            "Total Pseudo"
        ])

        writer.writerows(history)

    print(f"[INFO] Results saved to: {csv_path}")
        
        