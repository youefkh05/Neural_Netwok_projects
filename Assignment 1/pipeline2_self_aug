        plt.axis('off')

    plt.suptitle("Random Samples")
    plt.show()


# ==============================
# SHOW 10 IMAGES PER CLASS
# ==============================
def show_class_samples(images, matrix, num_per_class=10):
    plt.figure(figsize=(num_per_class, 10))

    for digit in range(10):
        indices = matrix[digit][:num_per_class]

        for j, idx in enumerate(indices):
            plt.subplot(10, num_per_class, digit * num_per_class + j + 1)
            plt.imshow(images[idx], cmap='gray')
            plt.axis('off')

            if j == 0:
                plt.ylabel(f"{digit}", rotation=0, labelpad=20, fontsize=12)

    plt.suptitle("10 Samples per Class", fontsize=16)
    plt.tight_layout()
    plt.show()

# ==============================
# SHOW AUGMENTATIONS FOR ONE IMAGE
# ==============================
def show_augmentation_variants(augmented_data, class_id, sample_idx=0):
    """
    augmented_data: (10, 240, H, W)
    class_id: 0–9
    sample_idx: which base image (0–29)
    """

    SAVE_PATH = os.path.join(OUTPUT_DIR, f"class_{class_id}_sample_{sample_idx}.png")

    # each image has 8 versions (1 original + 7 aug)
    start = sample_idx * 8
    end = start + 8

    variants = augmented_data[class_id][start:end]

    plt.figure(figsize=(12, 2))

    titles = [
        "Original",
        "+5°",
        "-5°",
        "Noise",
        "Right",
        "Left",
        "Down",
        "Up"
    ]

    for i in range(8):
        plt.subplot(1, 8, i+1)
        plt.imshow(variants[i], cmap='gray')
        plt.title(titles[i], fontsize=8)
        plt.axis('off')

    plt.suptitle(f"Class {class_id} — Sample {sample_idx}", fontsize=14)
    plt.tight_layout()

    # save figure
    plt.savefig(SAVE_PATH, dpi=300)
    print(f"[INFO] Saved augmentation figure at: {SAVE_PATH}")

    plt.show()


# ==============================
# SHOW HARD SAMPLES (DEBUG)
# ==============================
def show_hard_samples(images, hard_samples, labels, n=10, save=False, iteration=None):
    plt.figure(figsize=(12, 2))

    for i in range(min(n, len(hard_samples))):
        idx = hard_samples[i]

        plt.subplot(1, n, i+1)
