import matplotlib.pyplot as plt
from sklearn.cluster import KMeans
from check_accuracy import check_accuracy
from sklearn.svm import SVC
import csv


# ==============================
# CONFIG
# ==============================
BASE_DIR = os.path.dirname(__file__)

DATA_PATH = os.path.join(BASE_DIR, "Indian_Digits_Train")
IMG_SIZE = (32, 32)

IMAGES_CACHE = "images.npy"
FEATURES_CACHE = "features.npy"

# output directory for results 
OUTPUT_DIR = os.path.join(BASE_DIR, "pipeline2")

TARGET_PER_CLASS = 30
NUM_CLASSES = 10
N = 10000

# ==============================
# STEP 1 — Load Images
# ==============================
def load_images(path):
    files = [f for f in os.listdir(path) if f.endswith(".bmp")]
    
    # Sort numerically: 1.bmp → 10000.bmp
    files = sorted(files, key=lambda x: int(x.split('.')[0]))
    
    images = []
    
    for f in files:
        img_path = os.path.join(path, f)
        
        img = cv2.imread(img_path, cv2.IMREAD_GRAYSCALE)
        
        if img is None:
            raise ValueError(f"Error loading image: {img_path}")
        
        images.append(img)
    
    images = np.array(images)
    
    print(f"[INFO] Loaded {len(images)} images")
    
    return images

# ==============================
# STEP 2 AUGMENTATION FUNCTIONS
# ==============================

def rotate_image(img, angle):
    h, w = img.shape
    M = cv2.getRotationMatrix2D((w//2, h//2), angle, 1)
    return cv2.warpAffine(img, M, (w, h))


def add_noise(img):
    noise = np.random.normal(0, 10, img.shape)
    noisy = img + noise
    return np.clip(noisy, 0, 255).astype(np.uint8)


def shift_image(img, dx, dy):
    M = np.float32([[1, 0, dx], [0, 1, dy]])
    return cv2.warpAffine(img, M, (img.shape[1], img.shape[0]))

# ==============================
# STEP 2 — AUGMENT SEED DATA
# ==============================

def augment_seed(images, matrix):
    """
    images: full dataset (10000, H, W)
    matrix: (10, 30) seed indices

    returns:
        augmented_images_per_class (10, 120, H, W)
    """

    all_classes = []

    for digit in range(NUM_CLASSES):
        class_indices = matrix[digit]

        class_images = []

        for idx in class_indices:
            img = images[idx]

            # Original
            class_images.append(img)

            # Augmentations (7 per image)
            class_images.append(rotate_image(img, 5))
            class_images.append(rotate_image(img, -5))
            class_images.append(add_noise(img))

            # left, right, up, down shifts
            class_images.append(shift_image(img, 2, 0))
            class_images.append(shift_image(img, -2, 0))
            class_images.append(shift_image(img, 0, 2))
            class_images.append(shift_image(img, 0, -2))



        class_images = np.array(class_images)

        print(f"[INFO] Class {digit}: {class_images.shape}")

        all_classes.append(class_images)

    return np.array(all_classes)

# ==============================
# BUILD TRAINING SET
# ==============================
def build_training_set(augmented_data):
    X = []
    y = []
    weights = []

    for digit in range(NUM_CLASSES):
        class_data = augmented_data[digit]

        for i, img in enumerate(class_data):
            X.append(img)
            y.append(digit)

            # first 30 → original images
            if i < TARGET_PER_CLASS:
                weights.append(100)
            else:
                weights.append(1)

    X = np.array(X)
    y = np.array(y)
    weights = np.array(weights)

    print("[INFO] Training set shape:", X.shape)

    return X, y, weights

# ==============================
#  Extract HOG Features
# ==============================
def extract_hog_features(images):
    features = []
    
    for img in images:
        # Resize
        img_resized = cv2.resize(img, IMG_SIZE)
        
        # Extract HOG
        hog_feat = hog(
            img_resized,
            pixels_per_cell=(4, 4),
            cells_per_block=(2, 2),
            feature_vector=True
        )
        
        features.append(hog_feat)
    
    features = np.array(features)
    
    print(f"[INFO] HOG feature shape: {features.shape}")
    
    return features

# ==============================
# TRAIN SVM (SVM-1)
# ==============================
def train_svm(features, labels, weights):
    print("[INFO] Training SVM-1...")

    svm = SVC(
        kernel='rbf',
        decision_function_shape='ovo'
    )

    svm.fit(features, labels, sample_weight=weights)

    print("[INFO] SVM training complete.")

    return svm

# ==============================
# PREDICT FULL DATASET
# ==============================
def predict_full_dataset(svm, features):
    print("[INFO] Predicting full dataset...")

    predicted_labels = svm.predict(features)
    scores = svm.decision_function(features)

    print("[INFO] Prediction done.")

    return predicted_labels, scores


# ==============================
# HARD SAMPLES Extraction
# ==============================
def get_hard_samples(scores, used_indices, n_samples=20):
    # sort scores per row
    sorted_scores = np.sort(scores, axis=1)

    # margin = best - second best
    margin = sorted_scores[:, -1] - sorted_scores[:, -2]

    # exclude already used samples
    mask = np.ones(len(margin), dtype=bool)
    mask[list(used_indices)] = False

    filtered_indices = np.where(mask)[0]
    filtered_margin = margin[filtered_indices]

    # smallest margins
    sorted_idx = np.argsort(filtered_margin)
    hard_samples = filtered_indices[sorted_idx[:n_samples]]

    return hard_samples, margin

# ==============================
# LABEL HARD SAMPLES (SIMULATE HUMAN)
# ==============================
def get_true_labels_for_samples(samples):
    true_labels = []

    for sample in samples:
        best_label = 0
        best_acc = 0

        for digit in range(10):
            temp = np.zeros(N, dtype=int)
            temp[sample] = digit

            acc, _, _ = check_accuracy(temp)

            if acc > best_acc:
                best_acc = acc
                best_label = digit

        true_labels.append(best_label)

    return np.array(true_labels)



# ==============================
# STEP 5 — GET CONFIDENT SAMPLES
# ==============================
def get_confident_samples(predicted_labels, margin, used_indices):
    confident_samples = []

    threshold = np.percentile(margin, 75)

    for digit in range(NUM_CLASSES):
        # indices of this class
        class_idx = np.where(predicted_labels == digit)[0]

        # filter unused
        class_idx = [i for i in class_idx if i not in used_indices]

        # filter by margin threshold
        class_idx = [i for i in class_idx if margin[i] > threshold]

        # sort by confidence (descending margin)
        class_idx = sorted(class_idx, key=lambda i: margin[i], reverse=True)

        # take top 50
        confident_samples.extend(class_idx[:50])

    return np.array(confident_samples)


# ==============================
# UPDATE TRAINING SET
# ==============================
def update_training_set(
    X_train, y_train, weights,
    images, predicted_labels,
    hard_samples, hard_labels,
    confident_samples
):
    # add hard samples (human labeled)
    for idx, label in zip(hard_samples, hard_labels):
        X_train.append(images[idx])
        y_train.append(label)
        weights.append(100)

    # add confident samples (pseudo)
    for idx in confident_samples:
        X_train.append(images[idx])
        y_train.append(predicted_labels[idx])
        weights.append(1)

    return X_train, y_train, weights


