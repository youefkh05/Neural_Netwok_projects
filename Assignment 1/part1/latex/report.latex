  >{\raggedright\arraybackslash}p{(\columnwidth - 4\tabcolsep) * \real{0.3333}}@{}}
\toprule()
\begin{minipage}[b]{\linewidth}\raggedright
\textbf{Oil (gallons)}
\end{minipage} & \begin{minipage}[b]{\linewidth}\raggedright
\textbf{Temp (°F)}
\end{minipage} & \begin{minipage}[b]{\linewidth}\raggedright
\textbf{Insulation (in)}
\end{minipage} \\
\midrule()
\endhead
270 & 40 & 4 \\
362 & 27 & 4 \\
162 & 40 & 10 \\
45 & 73 & 6 \\
91 & 65 & 7 \\
\textbf{233} & \textbf{65} & \textbf{40 ← OUTLIER} \\
372 & 10 & 6 \\
